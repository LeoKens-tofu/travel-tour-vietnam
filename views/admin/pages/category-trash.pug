extends ../layouts/default.pug

block main
  h1.box-title Thùng rác category

  //- Section 5
  .section-5
    .inner-wrap
      .inner-change-status(check-multi data-api=`/${pathAdmin}/category/check-multi`)
        .inner-item
          select
            option(value="") -- Hành động --
            option(value="undo") Khôi phục
            option(value="destroy") Xóa vĩnh viễn  
        .inner-item
          button Áp dụng
      .inner-search
        <i class="fa-solid fa-magnifying-glass"></i>
        input(type="text" placeholder="Tìm kiếm" search)
  //- End Section 5

  //- Section 6
  .section-6
    .table-2
      table
        thead
          tr
            th(class="inner-center")
              input(type="checkbox" class="inner-check" check-all)
            th Tên danh mục
            th Ảnh đại diện
            th(class="inner-center") Vị trí
            th(class="inner-center") Trạng thái
            th Tạo bởi
            th Cập nhật bởi
            th Hành động
        tbody
          each item in categoryList
            tr
              td(class="inner-center")
                input(type="checkbox" class="inner-check" check-item=item.id)
              td #{item.name}
              td
                img(src=item.avatar class="inner-avatar")
              td(class="inner-center") #{item.position}
              td(class="inner-center")
                if (item.status == 'active')
                  .badge.badge-green #{item.status}
                else if (item.status == 'inactive') 
                  .badge.badge-red #{item.status}
                else 
                  .badge.badge-orange #{item.status}
              td
                div #{item.createdByName}
                div.inner-time #{item.createByTimeFormat}
              td
                div #{item.updatedByName}
                div.inner-time #{item.updateByTimeFormat}
              td
                .inner-buttons
                  button(class="inner-undo" btn-undo data-api=`/${pathAdmin}/category/trash/undo/${item.id}`) <i class="fa-solid fa-rotate-left"></i>
                  button(class="inner-delete" btn-destroy data-api=`/${pathAdmin}/category/trash/destroy/${item.id}`) <i class="fa-regular fa-trash-can"></i>
  //- End Section 6
  //- End Section 6

  //- Section 7
  .section-7
    span(class="inner-label") Hiển thị #{pagination.skip + 1} - #{pagination.skip + categoryList.length} của #{pagination.totalRecord}
    select(class="inner-pagination" pagination)
      - for (let i = 1; i <= pagination.totalPage; i++)
        option(value=i) Trang #{i}
  //- End Section 7