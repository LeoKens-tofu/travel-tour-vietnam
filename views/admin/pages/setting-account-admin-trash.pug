extends ../layouts/default.pug

block main
  h1.box-title Thùng rác AccountAdmin

  //- Section 5
  .section-5
    .inner-wrap
      .inner-change-status(check-multi data-api=`/${pathAdmin}/tour/check-multi`)
        .inner-item
          select
            option(value="") -- Hành động --
            option(value="undo") Khôi phục
            option(value="destroy") Xóa vĩnh viễn  
        .inner-item
          button Áp dụng
      .inner-search
        <i class="fa-solid fa-magnifying-glass"></i>
        input(type="text" placeholder="Tìm kiếm" search)
  //- End Section 5

  //- Section 6
  .section-6
    .table-2
      table
        thead
          tr
            th(class="inner-center")
              input(type="checkbox" class="inner-check")
            th Họ tên
            th(class="inner-center") Ảnh đại diện
            th Email
            th Số điện thoại
            th Nhóm quyền
            th Chức vụ
            th Trạng thái
            th Hành động
        tbody
          each item in accountAdminList
            tr
              td(class="inner-center")
                input(type="checkbox" class="inner-check")
              td #{item.fullName}
              td(class="inner-center")
                img(src=item.avatar class="inner-avatar")
              td #{item.email}
              td #{item.phone}
              td #{item.roleName}
              td #{item.positionCompany}
              td
                if (item.status == 'active')
                  .badge.badge-green #{item.status}
                else if (item.status == 'inactive') 
                  .badge.badge-red #{item.status}
                else 
                  .badge.badge-orange #{item.status}
              td
                .inner-buttons
                  button(class="inner-undo" btn-undo data-api=`/${pathAdmin}/setting/account-admin/undo/${item.id}`) <i class="fa-solid fa-rotate-left"></i>
                  button(class="inner-delete" btn-destroy data-api=`/${pathAdmin}/setting/account-admin/trash/destroy/${item.id}`) <i class="fa-regular fa-trash-can"></i>
  //- End Section 6

  //- Section 7
  .section-7
    span(class="inner-label") Hiển thị 1 - 9 của 78
    select(class="inner-pagination")
      option Trang 1
      option Trang 2
      option Trang 3
  //- End Section 7
  .section-8
    .inner-back
      a(href=`/${pathAdmin}/setting/account-admin/list`) Quay lại danh sách