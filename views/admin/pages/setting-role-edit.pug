extends ../layouts/default.pug

block main
  h1.box-title Sửa nhóm quyền

  .section-8
    form#setting-role-edit-form
      .inner-group(style='display: none;')
        label(class="inner-label" for="ID") ID
        input(type="text" id="ID" name="ID" value=roleDetail.id)
      .inner-group
        label(class="inner-label" for="name") Tên nhóm quyền
        input(type="text" id="name" name="name" value=roleDetail.name)
      .inner-group
        label(class="inner-label" for="description") Mô tả ngắn
        input(type="text" id="description" name="description" value=roleDetail.description)
      .inner-group
        label(class="inner-label") Phân quyền
        .inner-checkbox-list
          each item in permissionList
            .inner-checkbox-item
              input(type="checkbox" name="permissions" value=item.value id=`permission-${item.value}` checked=(roleDetail.permissions.includes(item.value)))
              label(for=`permission-${item.value}`) #{item.label}
      .inner-button.inner-two-col
        button#btnSummit Cập nhật
      div#loader
    .inner-back
      a(href=`/${pathAdmin}/setting/role/list`) Quay lại danh sách