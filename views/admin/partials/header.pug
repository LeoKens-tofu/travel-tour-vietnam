header.header
  .inner-logo
    a(href=`/${pathAdmin}/dashboard`)
      span 28
      span Admin
  .inner-wrap
    .inner-notify
      img(src="/admin/assets/images/icon-bell.svg", alt="")
      span 6
    a.inner-account(href=`/${pathAdmin}/profile/edit`)
      .inner-avatar
        img(src="/admin/assets/images/avatar.jpg", alt="")
      .inner-text
        .inner-name #{account.fullName}
        .inner-role Admin
    button.inner-button-menu
      <i class="fa-solid fa-bars"></i>