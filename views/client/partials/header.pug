// Top Header
.top-header
  .container
    .inner-wrap
      .inner-item
        i.fa-solid.fa-phone
        | #{WebInfo.phone}
      .inner-item
        i.fa-solid.fa-envelope
        | #{WebInfo.email}
      .inner-item
        i.fa-solid.fa-building
        | #{WebInfo.address}
// End Top Header
// Header
header.header
  .container
    .inner-wrap
      // Menu Mobile
      button.inner-menu-mobile
        i.fa-solid.fa-bars
      // Logo
      .inner-logo
        a(href=`/`)
          img(
            alt=WebInfo.websiteName
            src="/assets/images/logo.png"
            )
      // Menu
      nav.inner-menu
        ul
          li
            a.active(href="/") Trang chủ
          each item in categoryList 
            li
              a(href=`/category/${item.slug}`) #{item.name}
              if (item.child && item.child.length > 0)
                i.fa-solid.fa-caret-down
                ul
                  each itemChild in item.child 
                    li
                      a(href=`/category/${itemChild.slug}`) #{itemChild.name}
          li
            a(href="#") Tin tức
          li
            a(href="#") Liên hệ
        .inner-overlay
      // Cart
      .inner-cart
        a(href="/cart")
          img(
            alt="Cart" 
            src="/assets/images/icon-cart.svg"
            )
          span 0
// End Header