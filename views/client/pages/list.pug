extends ../layouts/default.pug
include ../mixins/product.pug
include ../mixins/breadcrum.pug

block main     
    +breadcrumb(breadcrumb, "category")
    // Section 9
    .section-9
        .container
            .inner-wrap
                .inner-left
                    // Box Filter
                    .box-filter
                        .inner-head
                            .inner-title Bộ Lọc
                            i.fa-solid.fa-square-xmark(filter-reset)
                        .inner-body
                            .inner-group
                                .inner-label Điểm đi
                                select(name="locationFrom")
                                    option(value="") -- Chọn điểm đi --
                                    each item in cityList
                                        option(value=item.id) #{item.name}
                            .inner-group
                                .inner-label Điểm đến
                                select(name="locationTo")
                                    option(value="") -- Chọn điểm đến --
                                    each item in cityList
                                        option(value=item.name) #{item.name}
                            .inner-group
                                .inner-label Ngày khởi hành
                                input(type="date" name="departureDate")
                            .inner-group
                                .inner-label Số Lượng Hành Khách
                                .inner-input-list
                                    .inner-input-item
                                        .inner-label Người lớn:
                                        input(
                                            value="0" 
                                            type="number"
                                            name="stockAdult"
                                            )
                                    .inner-input-item
                                        .inner-label Trẻ em:
                                        input(
                                            value="0" 
                                            type="number"
                                            name="stockChild"
                                            )
                                    .inner-input-item
                                        .inner-label Em bé:
                                        input(
                                            value="0" 
                                            type="number"
                                            name='stockBaby'
                                            )
                            .inner-group
                                .inner-label Mức giá
                                #slider(style="width: 100%; margin-top: 40px;")
                            .inner-group
                                button.inner-button Áp Dụng
                    .inner-overlay
                    // End Box Filter
                .inner-right
                    .inner-info
                        h2.inner-title #{categoryDetail.name}
                        .inner-desc !{categoryDetail.description}
                    .inner-info-2
                        .inner-sort
                            .inner-label Sắp xếp:
                            .inner-list
                                button
                                    | Giá tăng dần
                                    i.fa-solid.fa-square-caret-up
                                button
                                    | Giá giảm dần
                                    i.fa-solid.fa-square-caret-down
                                button.active
                                    | Khuyến Mại Hot
                                    i.fa-solid.fa-tag
                                button
                                    | Xem Nhiều
                                    i.fa-solid.fa-eye
                        .inner-count-record
                            | Tất cả:
                            b #{tourList.length}
                        button.inner-filter-mobile
                            span.inner-title Bộ Lọc
                            i.fa-solid.fa-filter
                    .inner-list-tour
                        each item in tourList
                            // Product Item
                            +product-item(item)
                            // End Product Item
                    .box-pagination
                        button
                            i.fa-solid.fa-angles-left
                        button.active 1
                        button 2
                        button 3
                        button 4
                        button
                            i.fa-solid.fa-angles-right 
                    // End Pagination
                    // End Section 9
