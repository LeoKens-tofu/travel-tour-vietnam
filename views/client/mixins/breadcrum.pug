mixin breadcrumb(list, name)
    // Breadcrumb
    - const itemLast = list[list.length - 1];
    .box-breadcrumb
        .inner-image
            img(
            alt=itemLast.name
            src=itemLast.avatar
            )
        .inner-content
            .container
                h1.inner-title #{itemLast.name}
                .inner-list
                    a(href="/") Trang Chủ
                    each item in list
                        if (name == 'category')
                            a(href=`/category/${item.slug}`) #{item.name}
                        else 
                            a(href=`/tour/detail/${item.slug}`) #{item.name}
    // End Breadcrumb